{
  "name": "codex-account-helper",
  "displayName": "codex账号助手",
  "description": "Manage multiple Codex auth.json accounts inside VS Code.",
  "version": "0.0.2",
  "publisher": "caok",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:codexSwitch.accountsView",
    "onCommand:codexSwitch.addAccount",
    "onCommand:codexSwitch.switchAccount",
    "onCommand:codexSwitch.removeAccount",
    "onCommand:codexSwitch.refreshAccounts",
    "onCommand:codexSwitch.focusAccountsView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexSwitch.addAccount",
        "title": "codex账号助手: 添加账号"
      },
      {
        "command": "codexSwitch.switchAccount",
        "title": "codex账号助手: 切换账号"
      },
      {
        "command": "codexSwitch.removeAccount",
        "title": "codex账号助手: 删除账号"
      },
      {
        "command": "codexSwitch.refreshAccounts",
        "title": "codex账号助手: 刷新账号"
      },
      {
        "command": "codexSwitch.focusAccountsView",
        "title": "codex账号助手: 打开账号面板"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexSwitch",
          "title": "账号助手",
          "icon": "$(account)"
        }
      ]
    },
    "views": {
      "codexSwitch": [
        {
          "id": "codexSwitch.accountsView",
          "name": "账号助手",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "codex账号助手",
      "properties": {
        "codexSwitch.authFilePath": {
          "type": "string",
          "default": "~/.codex/auth.json",
          "description": "Path to the live Codex auth.json file."
        },
        "codexSwitch.storageDirectory": {
          "type": "string",
          "default": "~/.codex/auth-profiles",
          "description": "Directory used to store saved Codex auth.json profiles."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.1",
    "typescript": "^5.5.4"
  }
}
